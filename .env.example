# ============================================================
# GreenAndCoop - Configuration Environment
# Copier ce fichier en .env et remplir les vraies valeurs
# ============================================================

# PostgreSQL
POSTGRES_USER=greencoop_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=greencoop
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# Airbyte
AIRBYTE_USERNAME=airbyte
AIRBYTE_PASSWORD=your_airbyte_password_here

# dbt
DBT_THREADS=4
DBT_PROFILES_DIR=./dbt

# Python
PYTHONUNBUFFERED=1
