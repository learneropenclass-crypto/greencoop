greencoop:
  outputs:
    dev:
      type: postgres
      host: localhost
      user: greencoop_user
      password: your_password_here
      port: 5432
      dbname: greencoop
      schema: public
      threads: 4
      keepalives_idle: 0

    prod:
      type: postgres
      host: prod-host.example.com
      user: prod_user
      password: prod_password_here
      port: 5432
      dbname: greencoop
      schema: public
      threads: 8
      keepalives_idle: 0

  target: dev
